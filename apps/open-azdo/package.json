{
  "name": "open-azdo",
  "version": "0.2.9",
  "description": "Secure Azure DevOps pull request review CLI powered by OpenCode",
  "repository": {
    "type": "git",
    "directory": "apps/open-azdo"
  },
  "bin": {
    "open-azdo": "./dist/open-azdo.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "examples"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build.ts",
    "sandbox:capture": "bun run ./bin/open-azdo.ts sandbox capture",
    "test:integration": "bun test ./test/live.integration.test.ts",
    "typecheck": "tsgo --noEmit --pretty false",
    "typecheck:tsc": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun install --cwd ../.. --frozen-lockfile && bun run --cwd ../.. check && bun run build"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.33",
    "@open-azdo/sandbox": "workspace:*",
    "effect": "4.0.0-beta.33"
  },
  "engines": {
    "bun": ">=1.3.10"
  }
}
