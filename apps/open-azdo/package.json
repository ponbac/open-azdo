{
  "name": "open-azdo",
  "version": "0.1.10",
  "description": "Secure Azure DevOps pull request review CLI powered by OpenCode",
  "repository": {
    "type": "git",
    "directory": "apps/open-azdo"
  },
  "bin": {
    "open-azdo": "./dist/open-azdo.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "examples"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.33",
    "@open-azdo/azdo": "workspace:*",
    "@open-azdo/core": "workspace:*",
    "@open-azdo/workflows": "workspace:*",
    "effect": "4.0.0-beta.33"
  },
  "engines": {
    "bun": ">=1.3.10"
  }
}
