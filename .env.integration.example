# Copy to .env.integration.local for opt-in live validation.

OPEN_AZDO_LIVE_MODEL=openai/gpt-5.4
OPEN_AZDO_LIVE_OPENCODE_VARIANT=high
OPEN_AZDO_LIVE_OPENCODE_TIMEOUT=10 minutes

OPEN_AZDO_LIVE_COLLECTION_URL=https://dev.azure.com/acme
OPEN_AZDO_LIVE_ORGANIZATION=acme
OPEN_AZDO_LIVE_PROJECT=project
OPEN_AZDO_LIVE_REPOSITORY_ID=repo-id
OPEN_AZDO_LIVE_PULL_REQUEST_ID=42

# Optional: provide a real checkout or let sandbox capture create a temporary one.
# OPEN_AZDO_LIVE_WORKSPACE=/abs/path/to/repo

# Required Azure DevOps auth.
OPEN_AZDO_LIVE_ACCESS_TOKEN=

# Required provider-native model auth.
OPENAI_API_KEY=
