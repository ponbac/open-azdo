{
  "name": "@open-azdo/root",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "typecheck:tsc": "turbo run typecheck:tsc",
    "lint": "bun run lint:type-aware",
    "lint:type-aware": "oxlint --config .oxlintrc.json --type-aware --type-check apps packages --report-unused-disable-directives",
    "lint:syntax": "oxlint --config .oxlintrc.json apps packages --report-unused-disable-directives",
    "fmt": "oxfmt --write apps packages AGENTS.md README.md package.json turbo.json tsconfig.base.json tsconfig.json",
    "test": "turbo run test",
    "check": "bun run fmt && bun run lint && bun run test",
    "publish:dry": "bash ./scripts/publish-npm.sh dry-run",
    "publish:npm": "bash ./scripts/publish-npm.sh"
  },
  "devDependencies": {
    "@effect/language-service": "0.81.0",
    "@types/bun": "1.3.10",
    "@typescript/native-preview": "7.0.0-dev.20260321.1",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.1",
    "turbo": "^2.8.18",
    "typescript": "6.0.0-dev.20260321"
  },
  "packageManager": "bun@1.3.10"
}
