{
  "name": "@open-azdo/root",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "sandbox:capture": "bun --env-file=../../.env.integration.local run --cwd apps/open-azdo sandbox:capture",
    "sandbox:dev": "bun run --cwd apps/sandbox dev",
    "sandbox:preview": "bun run --cwd apps/sandbox preview",
    "typecheck": "turbo run typecheck",
    "typecheck:tsc": "turbo run typecheck:tsc",
    "lint": "bun run lint:type-aware",
    "lint:type-aware": "oxlint --config .oxlintrc.json --type-aware --type-check apps packages --report-unused-disable-directives",
    "lint:syntax": "oxlint --config .oxlintrc.json apps packages --report-unused-disable-directives",
    "fmt": "oxfmt --write apps packages AGENTS.md README.md package.json turbo.json tsconfig.base.json tsconfig.json",
    "test": "turbo run test",
    "test:integration": "bun --env-file=../../.env.integration.local run --cwd apps/open-azdo test:integration",
    "check": "bun run fmt && bun run lint && bun run test",
    "publish:dry": "bash ./scripts/publish-npm.sh dry-run",
    "publish:npm": "bash ./scripts/publish-npm.sh"
  },
  "devDependencies": {
    "@effect/language-service": "0.84.1",
    "@types/bun": "1.3.11",
    "@types/turndown": "5.0.6",
    "@typescript/native-preview": "7.0.0-dev.20260327.2",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "turbo": "^2.8.21",
    "typescript": "6.0.2"
  },
  "packageManager": "bun@1.3.10"
}
