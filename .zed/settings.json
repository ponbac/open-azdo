{
  "auto_install_extensions": {
    "oxc": true
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "vtsls": {
          "autoUseWorkspaceTsdk": true
        }
      }
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": ".oxlintrc.json",
          "run": "onType",
          "disableNestedConfig": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": ".oxfmtrc.json",
          "run": "onSave"
        }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": ["vtsls", "oxlint", "!eslint", "!biome", "..."],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "JSX": {
      "language_servers": ["vtsls", "oxlint", "!eslint", "!biome", "..."],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": {
        "language_server": {
          "name": "oxfmt"
        }
      }
    },
    "TypeScript": {
