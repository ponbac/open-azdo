{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!.turbo/**", "!dist/**", "!coverage/**", "!tsconfig.tsbuildinfo"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", "!.turbo/**", "!dist/**", "!coverage/**", "!tsconfig.tsbuildinfo"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["$TURBO_DEFAULT$", "!.turbo/**", "!dist/**", "!coverage/**", "!tsconfig.tsbuildinfo"],
      "outputs": []
    }
  }
}
